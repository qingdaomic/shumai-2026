   sol:"PA=√(100-36)=8；OB=R=6；PB=PO-OB=4；S△PAB=½×PA×OA×sinA?；用面积法：S△OAB=½×OA×h，h=PA×OB/PO",error:"切线与弦的面积计算"},
  {id:321,yr:2023,no:21,city:"青岛",type:"solve",topic:"quadrilateral",score:10,diff:4,
