   sol:"△ABC等腰直角→∠B=∠C=45°；BD=DC（D为BC中点，因为△ABC等腰直角）；AAS",error:"等腰直角三角形的特殊性质"},
  {id:319,yr:2021,no:19,city:"青岛",type:"solve",topic:"similar",score:10,diff:4,
