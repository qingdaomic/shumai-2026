    {id:"b_sim_02",diff:2,content:"面积比4:9，相似比和周长比",answer:"相似比2:3，周长比2:3",sol:"面积比=相似比²",error:"面积比开方",upLink:["tg05","tg07"],downLink:[]},
    {id:"b_sim_03",diff:2,content:"DE∥BC，AD=3，DB=2，DE=6，BC=？",answer:"10",sol:"AD/AB=3/5=DE/BC",error:"平行截割比例",upLink:["tg05","tg07"],downLink:[],
     svg:`<svg width="200" height="170" viewBox="0 0 200 170" xmlns="http://www.w3.org/2000/svg" style="background:#0d1825;border-radius:8px;display:block">
