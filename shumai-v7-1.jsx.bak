   sol:"∠DEA=∠FEB（对顶角）；∠A=∠B=90°→AA相似；EA=1，EB=2，相似比1:2；BF=2；CF=4-2... 需要重新分析图形",error:"矩形中的相似三角形"},
  {id:322,yr:2024,no:21,city:"青岛",type:"solve",topic:"quad_fn",score:12,diff:5,
