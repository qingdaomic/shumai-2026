  {id:"m3",label:"题组训练",icon:"③",color:C.m3,desc:"35组提高题，构建方法体系"},
  {id:"m4",label:"压轴题组",icon:"④",color:C.m4,desc:"20组压轴，催生解题灵感"},
];

