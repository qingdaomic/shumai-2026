   sol:"对称轴x=2；y(2)=4+2b+c；由A代入得b=-4，c=3；y(2)=-1",error:"由零点求顶点"},
  {id:124,yr:2019,no:16,city:"上海",type:"fill",topic:"circle",score:4,diff:3,
   subTopics:["circle","trig"],methods:["m07","m16"],
