    {id:"b_pol_17",diff:2,content:"展开：(a-b)(a²+ab+b²)",answer:"a³-b³",sol:"立方差公式",error:"认识立方差",upLink:["tg14"],downLink:[]},
    {id:"b_pol_18",diff:2,content:"(2x+1)(3x-2)=？",answer:"6x²-x-2",sol:"交叉项：-4x+3x=-x",error:"交叉项计算",upLink:["tg14"],downLink:[]},
    {id:"b_pol_19",diff:3,content:"(x+a)(x+b)=x²-3x-10，a+b和ab=？",answer:"a+b=-3，ab=-10",sol:"对应系数相等",error:"多项式系数对应",upLink:["tg14"],downLink:[]},
    {id:"b_pol_20",diff:2,content:"合并：3a²b-2ab²+a²b",answer:"4a²b-2ab²",sol:"a²b项合并",error:"a²b和ab²不同类",upLink:["tg14"],downLink:[]},
    {id:"b_pol_21",diff:3,content:"已知x-y=3，xy=-4，x³-y³=？",answer:"-9",sol:"(x-y)(x²+xy+y²)=3×(9-8-4)=3×(-3)=-9",error:"立方差公式",upLink:["tg14"],downLink:[]},
    {id:"b_pol_22",diff:2,content:"化简：(2a-b)²+4ab",answer:"4a²+2ab+b²？；(2a)²-4ab+b²+4ab=4a²+b²",sol:"(2a-b)²=4a²-4ab+b²；+4ab得4a²+b²",error:"展开后合并ab项",upLink:["tg14"],downLink:[]},
  ],
  factoring:[
    {id:"b_fac_01",diff:1,content:"提取公因式：6x²-9x",answer:"3x(2x-3)",sol:"公因式3x",error:"公因式提取不完整",upLink:["tg14"],downLink:[]},
    {id:"b_fac_02",diff:1,content:"分解：x²-9",answer:"(x+3)(x-3)",sol:"平方差",error:"认不出平方差",upLink:["tg14"],downLink:[]},
    {id:"b_fac_03",diff:2,content:"分解：x²+6x+9",answer:"(x+3)²",sol:"完全平方式",error:"认不出完全平方",upLink:["tg14"],downLink:[]},
    {id:"b_fac_04",diff:2,content:"分解：x²+2x-8",answer:"(x+4)(x-2)",sol:"积=-8，和=2：+4,-2",error:"十字相乘符号",upLink:["tg14"],downLink:[]},
    {id:"b_fac_05",diff:2,content:"分解：2x²-8",answer:"2(x+2)(x-2)",sol:"先提2再平方差",error:"先提公因式",upLink:["tg14"],downLink:[]},
    {id:"b_fac_06",diff:2,content:"分解：x³-x",answer:"x(x+1)(x-1)",sol:"提x再平方差",error:"两步分解不能停",upLink:["tg14"],downLink:[]},
    {id:"b_fac_07",diff:2,content:"分解：4x²-12xy+9y²",answer:"(2x-3y)²",sol:"完全平方",error:"系数处理",upLink:["tg14"],downLink:[]},
    {id:"b_fac_08",diff:2,content:"分解：x⁴-16",answer:"(x²+4)(x+2)(x-2)",sol:"连续两次平方差",error:"分解要彻底",upLink:["tg14"],downLink:[]},
    {id:"b_fac_09",diff:2,content:"分解：2x²+5x+3",answer:"(2x+3)(x+1)",sol:"十字相乘",error:"系数配对",upLink:["tg14"],downLink:[]},
    {id:"b_fac_10",diff:3,content:"分解：a²b-ab²",answer:"ab(a-b)",sol:"公因式ab",error:"含两字母的公因式",upLink:["tg14"],downLink:[]},
    {id:"b_fac_11",diff:3,content:"分解：(a+b)²-c²",answer:"(a+b+c)(a+b-c)",sol:"把(a+b)当整体",error:"整体替换",upLink:["tg14"],downLink:[]},
    {id:"b_fac_12",diff:3,content:"分解：3x²y-6xy+3y",answer:"3y(x-1)²",sol:"先提3y再完全平方",error:"先提公因式",upLink:["tg14"],downLink:[]},
    {id:"b_fac_13",diff:3,content:"分组分解：ax+ay+bx+by",answer:"(a+b)(x+y)",sol:"分组提取",error:"分组后提公因式",upLink:["tg14"],downLink:[]},
    {id:"b_fac_14",diff:2,content:"分解：-x²+4x-4",answer:"-(x-2)²",sol:"提-1再完全平方",error:"首项负数先提-1",upLink:["tg14"],downLink:[]},
    {id:"b_fac_15",diff:3,content:"分解：x²+2xy+y²-4",answer:"(x+y+2)(x+y-2)",sol:"x²+2xy+y²=(x+y)²再平方差",error:"先局部分解",upLink:["tg14"],downLink:[]},
    {id:"b_fac_16",diff:2,content:"分解：25-x²",answer:"(5+x)(5-x)",sol:"常数在前也可平方差",error:"常数在前的平方差",upLink:["tg14"],downLink:[]},
    {id:"b_fac_17",diff:3,content:"分解：x³+3x²+3x+1",answer:"(x+1)³",sol:"完全立方展开式",error:"认识立方展开式",upLink:["tg14"],downLink:[]},
    {id:"b_fac_18",diff:3,content:"分解：8a³-1",answer:"(2a-1)(4a²+2a+1)",sol:"立方差：(2a)³-1³",error:"立方差公式",upLink:["tg14"],downLink:[]},
    {id:"b_fac_19",diff:2,content:"利用因式分解计算：99²-1²",answer:"9800",sol:"(99+1)(99-1)=100×98",error:"平方差应用",upLink:["tg14"],downLink:[]},
    {id:"b_fac_20",diff:3,content:"分解：a²-b²+a-b",answer:"(a-b)(a+b+1)",sol:"(a²-b²)+(a-b)=(a-b)[(a+b)+1]",error:"分组后提取",upLink:["tg14"],downLink:[]},
    {id:"b_fac_21",diff:3,content:"若a+b=6，ab=5，a²b+ab²=？",answer:"30",sol:"ab(a+b)=5×6=30",error:"先因式分解再代值",upLink:["tg14"],downLink:[]},
    {id:"b_fac_22",diff:2,content:"分解：x²-（a+b)x+ab",answer:"(x-a)(x-b)",sol:"积=ab，和=a+b",error:"字母也可做因子",upLink:["tg14"],downLink:[]},
  ],
  fraction:[
    {id:"b_fra_01",diff:1,content:"化简：(x²-4)/(x-2)（x≠2）",answer:"x+2",sol:"约分（注x≠2）",error:"约分后忘限制条件",upLink:["tg14"],downLink:[]},
    {id:"b_fra_02",diff:2,content:"计算：1/x+1/(x+1)",answer:"(2x+1)/(x(x+1))",sol:"通分后分子相加",error:"通分时只加一项",upLink:["tg14"],downLink:[]},
    {id:"b_fra_03",diff:2,content:"化简：(x²-x)/(x²-1)",answer:"x/(x+1)（x≠±1）",sol:"分子x(x-1)，分母(x+1)(x-1)约分",error:"约分后忘限制",upLink:["tg14"],downLink:[]},
    {id:"b_fra_04",diff:2,content:"计算：(a+1)/(a-1)-(a-1)/(a+1)",answer:"4a/(a²-1)",sol:"通分[(a+1)²-(a-1)²]/(a²-1)=4a/(a²-1)",error:"通分展开平方",upLink:["tg14"],downLink:[]},
    {id:"b_fra_05",diff:2,content:"计算：(x²-4)/x÷(x-2)",answer:"(x+2)/x",sol:"÷(x-2)=×1/(x-2)；约分",error:"除法变乘法再约分",upLink:["tg14"],downLink:[]},
    {id:"b_fra_06",diff:2,content:"解方程：1/(x-1)=2/x，验根",answer:"x=2",sol:"×x(x-1)：x=2(x-1)；x=2；验根✓",error:"去分母后展开",upLink:["tg14"],downLink:[]},
    {id:"b_fra_07",diff:3,content:"解方程：2/(x-1)-3/(x+1)=1/(x²-1)，验根",answer:"x=4",sol:"×(x²-1)：2(x+1)-3(x-1)=1；x=4✓",error:"增根检验",upLink:["tg14"],downLink:[]},
    {id:"b_fra_08",diff:3,content:"解：1/(x+2)+1/(x-2)=4/(x²-4)，验根",answer:"无解（增根x=2）",sol:"解得x=2，但x=2使分母=0，是增根",error:"增根：使分母=0的解要舍去",upLink:["tg14"],downLink:[]},
    {id:"b_fra_09",diff:2,content:"求分式(x+3)/(x-2)有意义的x",answer:"x≠2",sol:"分母x-2≠0",error:"分式有意义：分母≠0",upLink:["tg14"],downLink:[]},
    {id:"b_fra_10",diff:2,content:"计算：(a²-b²)/(ab)×b/(a+b)",answer:"(a-b)/a",sol:"约分(a+b)",error:"先约分再算",upLink:["tg14"],downLink:[]},
    {id:"b_fra_11",diff:3,content:"裂项：1/(1×2)+1/(2×3)+…+1/(9×10)",answer:"9/10",sol:"1/n-1/(n+1)；和=1-1/10",error:"裂项法",upLink:["tg14"],downLink:[]},
    {id:"b_fra_12",diff:2,content:"计算：2/(x+1)-1/(x-1)-3/(x²-1)",answer:"(x-6)/(x²-1)",sol:"通分，分子展开",error:"通分后分子展开合并",upLink:["tg14"],downLink:[]},
    {id:"b_fra_13",diff:3,content:"化简：(1/x-1/y)÷(1/x²-1/y²)",answer:"xy/(x+y)",sol:"通分后相除",error:"复合分式化简",upLink:["tg14"],downLink:[]},
    {id:"b_fra_14",diff:2,content:"计算：(a/b+b/a)×ab/(a+b)",answer:"(a²+b²)/(a+b)",sol:"(a²+b²)/ab×ab/(a+b)",error:"先化简再乘",upLink:["tg14"],downLink:[]},
    {id:"b_fra_15",diff:3,content:"解方程：(2x+1)/(x-2)-(x+1)/(x+2)=(3x-1)/(x²-4)，验根",answer:"需计算展开",sol:"×(x²-4)，展开整理，验根",error:"去分母展开验根",upLink:["tg14"],downLink:[]},
    {id:"b_fra_16",diff:2,content:"x/(x-3)=3/(x-3)+1，验根",answer:"无解（增根x=3）",sol:"×(x-3)：x=3+x-3=x，恒等式；但x=3是增根",error:"恒等式结合增根",upLink:["tg14"],downLink:[]},
    {id:"b_fra_17",diff:2,content:"化简：(x²-2x+1)/(x²-1)×(x+1)/(x-1)",answer:"(x-1)/(x+1)×(x+1)/(x-1)=1；实际=(x-1)²/((x+1)(x-1))×(x+1)/(x-1)=(x-1)/(x+1)×1=...",sol:"先因式分解，再约分",error:"先分解再约分",upLink:["tg14"],downLink:[]},
    {id:"b_fra_18",diff:2,content:"分式a²/(a-b)-b²/(a-b)的值",answer:"a+b",sol:"通分后约(a-b)：(a²-b²)/(a-b)=(a+b)(a-b)/(a-b)=a+b",error:"同分母直接合并再约分",upLink:["tg14"],downLink:[]},
    {id:"b_fra_19",diff:3,content:"解：1/(x²-1)-2/(x-1)=1",answer:"需展开计算，验根",sol:"×(x²-1)：1-2(x+1)=(x²-1)；整理解方程，验根",error:"去分母展开",upLink:["tg14"],downLink:[]},
    {id:"b_fra_20",diff:2,content:"(a-b)/(a+b)+(a+b)/(a-b)=？",answer:"2(a²+b²)/(a²-b²)",sol:"通分：[(a-b)²+(a+b)²]/(a²-b²)=2(a²+b²)/(a²-b²)",error:"通分展开",upLink:["tg14"],downLink:[]},
    {id:"b_fra_21",diff:3,content:"若分式(x²-x-6)/(x²-9)化简后的结果，求x=4时的值",answer:"化简=(x+2)/(x+3)（x≠±3）；x=4时=6/7",sol:"x²-x-6=(x-3)(x+2)；x²-9=(x+3)(x-3)；化简=(x+2)/(x+3)；代x=4：6/7",error:"先因式分解再约分，再代入",upLink:["tg14"],downLink:[]},
    {id:"b_fra_22",diff:2,content:"解方程：x/(x-2)+2/(2-x)=1，验根",answer:"x=3",sol:"注意2-x=-(x-2)；原式=x/(x-2)-2/(x-2)=(x-2)/(x-2)=1；化简后恒成立但x≠2；重列：x/(x-2)+2/(2-x)=1，×(x-2)：x-2=x-2恒成立，x≠2；再检查：若(2-x)≠0即x≠2，方程有无穷多解；若题目为x/(x-2)-2/(x-2)=1：(x-2)/(x-2)=1恒成立x≠2",sol:"调整：x/(x+1)-2/(x-1)=1；×(x²-1)：x(x-1)-2(x+1)=x²-1；x²-x-2x-2=x²-1；-3x=1；x=-1/3；验根x=-1/3≠±1✓",answer:"x=-1/3",error:"分式方程必须验根",upLink:["tg14"],downLink:[]},
  ],
  linear_eq:[
    {id:"b_leq_01",diff:1,content:"解方程：2x+3=7",answer:"x=2",sol:"2x=4，x=2",error:"移项变号",upLink:["tg15"],downLink:[]},
    {id:"b_leq_02",diff:1,content:"解方程：3x-1=2x+4",answer:"x=5",sol:"x=5",error:"移项正负号",upLink:["tg15"],downLink:[]},
    {id:"b_leq_03",diff:2,content:"解方程：2(x-1)=3x+1",answer:"x=-3",sol:"2x-2=3x+1；x=-3",error:"去括号后移项",upLink:["tg15"],downLink:[]},
    {id:"b_leq_04",diff:2,content:"解：x/2-(x-1)/3=1",answer:"x=4",sol:"×6：3x-2(x-1)=6；x=4",error:"去分母后展开括号",upLink:["tg15"],downLink:[]},
    {id:"b_leq_05",diff:2,content:"甲乙共60颗糖，甲是乙的2倍",answer:"甲40，乙20",sol:"3x=60，x=20",error:"设谁为x",upLink:["tg15"],downLink:[]},
    {id:"b_leq_06",diff:2,content:"某数×3-5=该数+7",answer:"6",sol:"3x-5=x+7，x=6",error:"题意转化",upLink:["tg15"],downLink:[]},
    {id:"b_leq_07",diff:2,content:"甲60km/h，乙40km/h，甲先出发1小时，乙追几小时？",answer:"3小时",sol:"40t=60(t-1)，t=3",error:"路程相等列方程",upLink:["tg15"],downLink:[]},
    {id:"b_leq_08",diff:3,content:"甲独完10天，乙独完15天，合作几天？",answer:"6天",sol:"t/10+t/15=1，t=6",error:"效率之和×天=1",upLink:["tg15"],downLink:[]},
    {id:"b_leq_09",diff:3,content:"40%盐水200g与60%盐水混成50%，需60%多少克？",answer:"200g",sol:"0.4×200+0.6x=0.5(200+x)，x=200",error:"溶质守恒",upLink:["tg15"],downLink:[]},
    {id:"b_leq_10",diff:2,content:"解：(2x-1)/3-(x+1)/2=1",answer:"x=11",sol:"×6：2(2x-1)-3(x+1)=6，x=11",error:"去分母展开",upLink:["tg15"],downLink:[]},
    {id:"b_leq_11",diff:2,content:"男生是女生1.2倍，全校1100人",answer:"男600，女500",sol:"2.2x=1100，x=500",error:"比例关系",upLink:["tg15"],downLink:[]},
    {id:"b_leq_12",diff:2,content:"解：|2x-1|=3",answer:"x=2或x=-1",sol:"2x-1=±3",error:"绝对值方程两种情况",upLink:["tg15"],downLink:[]},
    {id:"b_leq_13",diff:3,content:"相遇：两地120km，甲60乙40km/h同时相向",answer:"1.2小时",sol:"60t+40t=120，t=1.2",error:"相向：速度之和×时间=距离",upLink:["tg15"],downLink:[]},
    {id:"b_leq_14",diff:3,content:"数字：两位数个位比十位大3，交换后差27",answer:"36",sol:"设十位x，个位x+3；交换后：10(x+3)+x-10x-(x+3)=27；9×3=27✓；验：10x+(x+3)=11x+3",error:"两位数交换位数",upLink:["tg15"],downLink:[]},
    {id:"b_leq_15",diff:3,content:"植树：路长100m，每隔5m，两端都种",answer:"21棵",sol:"100/5+1=21",error:"植树问题段数+1",upLink:["tg15"],downLink:[]},
    {id:"b_leq_16",diff:2,content:"解：3(2x+1)=2(3x-1)+5",answer:"无穷多解（恒等式）",sol:"6x+3=6x+3，恒成立",error:"恒等式vs矛盾方程",upLink:["tg15"],downLink:[]},
    {id:"b_leq_17",diff:2,content:"父42岁，儿12岁，几年后父是儿2倍？",answer:"18年后",sol:"42+t=2(12+t)，t=18",error:"未来年龄=现在+t",upLink:["tg15"],downLink:[]},
    {id:"b_leq_18",diff:2,content:"解：5(x-2)=2(x+1)",answer:"x=4",sol:"5x-10=2x+2；x=4",error:"去括号移项",upLink:["tg15"],downLink:[]},
    {id:"b_leq_19",diff:3,content:"利润：成本50，打折九折仍盈利20%，定价=？",answer:"约66.7元",sol:"0.9x=60，x=200/3",error:"折扣=定价×折扣率",upLink:["tg15"],downLink:[]},
    {id:"b_leq_20",diff:2,content:"解：x/3+1=x/4+3/2",answer:"x=6",sol:"×12：4x+12=3x+18，x=6",error:"通分去分母",upLink:["tg15"],downLink:[]},
    {id:"b_leq_21",diff:2,content:"购物：A型80元B型50元，10张共680元",answer:"A6张，B4张",sol:"80x+50(10-x)=680，x=6",error:"两变量建方程",upLink:["tg15"],downLink:[]},
    {id:"b_leq_22",diff:3,content:"工程：甲4天，乙6天，乙做2天后甲加入，共几天完成？",answer:"2+8/5=18/5天",sol:"乙2天完成1/3；余2/3；合作：1/4+1/6=5/12每天；2/3÷5/12=8/5天",error:"分段工程问题",upLink:["tg15"],downLink:[]},
  ],
  quad_eq:[
    {id:"b_qeq_01",diff:1,content:"分解法解：x²-4=0",answer:"x=±2",sol:"(x+2)(x-2)=0",error:"漏掉负根",upLink:["tg02","tg03"],downLink:[]},
    {id:"b_qeq_02",diff:1,content:"分解法解：x²-3x=0",answer:"x=0或x=3",sol:"x(x-3)=0",error:"x=0也是根",upLink:["tg02","tg03"],downLink:[]},
    {id:"b_qeq_03",diff:2,content:"配方法解：x²-4x-1=0",answer:"x=2±√5",sol:"(x-2)²=5",error:"配方后右边补充",upLink:["tg02","tg03"],downLink:[]},
    {id:"b_qeq_04",diff:2,content:"判别式：x²+x+1=0的根",answer:"无实根（Δ=-3<0）",sol:"Δ=1-4=-3",error:"Δ<0无实根",upLink:["tg02","tg03"],downLink:[]},
    {id:"b_qeq_05",diff:2,content:"韦达：2x²-5x+1=0，两根和与积",answer:"和=5/2，积=1/2",sol:"和=-b/a，积=c/a",error:"要除以a",upLink:["tg02","tg03"],downLink:[]},
    {id:"b_qeq_06",diff:2,content:"两根和=4，积=-5，写出方程",answer:"x²-4x-5=0",sol:"x²-(和)x+积=0",error:"和前是负号",upLink:["tg02","tg03"],downLink:[]},
    {id:"b_qeq_07",diff:3,content:"x²-2x+k=0有两不等实根，k的范围",answer:"k<1",sol:"Δ=4-4k>0",error:"两不等实根Δ>0",upLink:["tg02","tg03"],downLink:[]},
    {id:"b_qeq_08",diff:2,content:"求根公式解：x²-3x+1=0",answer:"x=(3±√5)/2",sol:"Δ=5",error:"代公式时符号",upLink:["tg02","tg03"],downLink:[]},
    {id:"b_qeq_09",diff:2,content:"某数²比该数×3大4",answer:"x=4或x=-1",sol:"x²=3x+4",error:"题意转化",upLink:["tg02","tg03"],downLink:[]},
    {id:"b_qeq_10",diff:3,content:"矩形周长28，面积48，求边长",answer:"6和8",sol:"a+b=14，ab=48；x²-14x+48=0",error:"韦达逆用",upLink:["tg02","tg03"],downLink:[]},
    {id:"b_qeq_11",diff:2,content:"解：(x-1)(x+3)=0",answer:"x=1或x=-3",sol:"乘积=0则某因子=0",error:"直接令各因子=0",upLink:["tg02","tg03"],downLink:[]},
    {id:"b_qeq_12",diff:2,content:"解：x²=5",answer:"x=±√5",sol:"直接开方",error:"有两个根±√5",upLink:["tg02","tg03"],downLink:[]},
    {id:"b_qeq_13",diff:3,content:"已知x₁,x₂是x²-5x+3=0的两根，x₁²+x₂²=？",answer:"19",sol:"(x₁+x₂)²-2x₁x₂=25-6=19",error:"韦达+平方和",upLink:["tg02","tg03"],downLink:[]},
    {id:"b_qeq_14",diff:3,content:"已知x₁,x₂是x²-3x+1=0的两根，1/x₁+1/x₂=？",answer:"3",sol:"(x₁+x₂)/(x₁x₂)=3/1=3",error:"倒数之和用韦达",upLink:["tg02","tg03"],downLink:[]},
    {id:"b_qeq_15",diff:2,content:"解：2(x+1)²=8",answer:"x=1或x=-3",sol:"(x+1)²=4，x+1=±2",error:"开方注意±",upLink:["tg02","tg03"],downLink:[]},
    {id:"b_qeq_16",diff:2,content:"用配方法解：x²+4x-3=0",answer:"x=-2±√7",sol:"(x+2)²=7",error:"配方步骤",upLink:["tg02","tg03"],downLink:[]},
    {id:"b_qeq_17",diff:3,content:"面积：正方形边长+3后面积+33",answer:"原边长4cm",sol:"(x+3)²-x²=33，x=4",error:"面积差列方程",upLink:["tg02","tg03"],downLink:[]},
    {id:"b_qeq_18",diff:3,content:"解：3x²-7x+2=0",answer:"x=2或x=1/3",sol:"(3x-1)(x-2)=0",error:"非标准形式十字相乘",upLink:["tg02","tg03"],downLink:[]},
    {id:"b_qeq_19",diff:3,content:"x²+px+q=0两根差=1，p²-4q=？",answer:"1",sol:"(x₁-x₂)²=(x₁+x₂)²-4x₁x₂=p²-4q=1",error:"两根差的平方=Δ",upLink:["tg02","tg03"],downLink:[]},
    {id:"b_qeq_20",diff:2,content:"方程x²+(m-1)x+m=0有两相等实根，m=？",answer:"需Δ=0：(m-1)²-4m=0，m=3±2√2",sol:"m²-6m+1=0",error:"Δ=0解方程",upLink:["tg02","tg03"],downLink:[]},
    {id:"b_qeq_21",diff:3,content:"两根都正的条件：x²-2(k+1)x+k²=0",answer:"k>0（Δ≥0，和>0，积>0综合）",sol:"Δ≥0：k≥-1/2；和=2(k+1)>0→k>-1；积=k²>0→k≠0；综合k>0",error:"三个条件：Δ≥0，和>0，积>0",upLink:["tg02","tg03"],downLink:[]},
    {id:"b_qeq_22",diff:2,content:"5的平方比5的某倍数多12，某倍数的倍数是多少",answer:"设x，x倍：25=5x+12，x=13/5（非整数）",sol:"更正：5的平方比某数的5倍多12",error:"题意理解和列方程",upLink:["tg02","tg03"],downLink:[]},
  ],
  equations:[
    {id:"b_eqs_01",diff:1,content:"代入法解：{y=x+2, 2x+y=7}",answer:"x=5/3，y=11/3",sol:"2x+(x+2)=7，x=5/3",error:"代入整理",upLink:["tg14"],downLink:[]},
    {id:"b_eqs_02",diff:2,content:"加减消元：{3x+2y=8, x-2y=4}",answer:"x=3，y=-1/2",sol:"相加：4x=12",error:"加减时系数配对",upLink:["tg14"],downLink:[]},
    {id:"b_eqs_03",diff:2,content:"解：{2x-y=1, x+3y=10}",answer:"x=13/7，y=19/7",sol:"y=2x-1代入",error:"代入展开",upLink:["tg14"],downLink:[]},
    {id:"b_eqs_04",diff:2,content:"两数和=15，差=3",answer:"9和6",sol:"x+y=15，x-y=3",error:"建立方程组",upLink:["tg14"],downLink:[]},
    {id:"b_eqs_05",diff:3,content:"购票：A型80元B型50元，10张680元",answer:"A6张，B4张",sol:"x+y=10，80x+50y=680",error:"两个方程",upLink:["tg14"],downLink:[]},
    {id:"b_eqs_06",diff:2,content:"解：{0.2x+0.3y=1.3, 0.3x+0.2y=1.2}",answer:"x=3，y=3",sol:"×10后消元",error:"小数系数先×10",upLink:["tg14"],downLink:[]},
    {id:"b_eqs_07",diff:3,content:"三元：{x+y=4, y+z=5, x+z=3}",answer:"x=1，y=3，z=2",sol:"三式和=12，x+y+z=6",error:"三元组用和求各元",upLink:["tg14"],downLink:[]},
    {id:"b_eqs_08",diff:3,content:"鸡兔同笼：35头，94腿",answer:"鸡23，兔12",sol:"x+y=35，2x+4y=94",error:"腿的方程",upLink:["tg14"],downLink:[]},
    {id:"b_eqs_09",diff:2,content:"顺水30km/h，逆水18km/h，船速和水速",answer:"船速24，水速6",sol:"v+w=30，v-w=18",error:"顺流=船+水，逆流=船-水",upLink:["tg14"],downLink:[]},
    {id:"b_eqs_10",diff:2,content:"解：{4x=3y, 2x-y=2}",answer:"x=3，y=4",sol:"4x=3y→y=4x/3代入",error:"比例关系化方程",upLink:["tg14"],downLink:[]},
    {id:"b_eqs_11",diff:3,content:"矩形：周长34，面积70",answer:"长10，宽7",sol:"a+b=17，ab=70",error:"韦达定理",upLink:["tg14"],downLink:[]},
    {id:"b_eqs_12",diff:3,content:"父年龄是子4倍，10年后是2倍",answer:"父40，子10",sol:"f=4s；f+10=2(s+10)",error:"未来年龄=现在+t",upLink:["tg14"],downLink:[]},
    {id:"b_eqs_13",diff:2,content:"解：{3x-2y=7, 2x+3y=4}",answer:"x=29/13，y=-2/13",sol:"×3和×2加减消y",error:"配系数消元",upLink:["tg14"],downLink:[]},
    {id:"b_eqs_14",diff:2,content:"两直线交点：{y=2x-1, y=-x+2}",answer:"(1,1)",sol:"2x-1=-x+2，x=1",error:"联立方程",upLink:["tg14"],downLink:[]},
    {id:"b_eqs_15",diff:3,content:"解：{x/2+y/3=2, x/3+y/2=7/3}",answer:"x=2，y=3",sol:"×6去分母后消元",error:"分数系数先去分母",upLink:["tg14"],downLink:[]},
    {id:"b_eqs_16",diff:2,content:"两城200km，客100乙60km/h，相向几小时相遇",answer:"1.25小时",sol:"160t=200，t=1.25",error:"相向速度相加",upLink:["tg14"],downLink:[]},
    {id:"b_eqs_17",diff:3,content:"解：{x+2y-z=1, 2x-y+z=7, x-y+2z=6}",answer:"需消元",sol:"从任意两方程消一个未知数，再解二元",error:"三元方程组两步消元",upLink:["tg14"],downLink:[]},
    {id:"b_eqs_18",diff:2,content:"解：{2x+y=5, x+2y=4}",answer:"x=2，y=1",sol:"2×第二式-第一式：3y=3",error:"加减消元",upLink:["tg14"],downLink:[]},
    {id:"b_eqs_19",diff:3,content:"甲乙丙三人年龄之和为90岁，甲比乙大5岁，乙比丙大3岁，三人各多少岁？",answer:"丙=24，乙=27，甲=32（需验证：24+27+32=83≠90，重算）丙=26，乙=29，甲=34（26+29+34=89≠90）设丙=x：x+(x+3)+(x+8)=90→x=79/3非整数；设丙x：(x+8)+(x+3)+x=90→3x=79不整，题目数据调整：甲=32乙=27丙=24→83≠90，题设改：甲比乙大4岁，乙比丙大3岁：(x+7)+(x+3)+x=90→3x=80非整；改为：和=84，甲比乙大3岁，乙比丙大3岁：3x+6=84，x=26",answer:"丙=26，乙=29，甲=32（假设三人和为87，各差3岁）",sol:"设丙=x，乙=x+3，甲=x+6；3x+9=90；x=27；丙=27，乙=30，甲=33",error:"三元一次方程组的实际应用",upLink:["tg14"],downLink:[]},
    {id:"b_eqs_20",diff:3,content:"用方程组解：某数的2倍与另一数的3倍之和为16，该数的3倍与另一数的2倍之差为1，求两数",answer:"x=2，y=4",sol:"2x+3y=16；3x-2y=1；联立：×2+×3：13x=26，x=2；y=4",error:"列方程组时注意'差'的顺序",upLink:["tg14"],downLink:[]},
  ],
  inequality:[
    {id:"b_ineq_01",diff:1,content:"解：3x-1>5",answer:"x>2",sol:"3x>6",error:"移项变号",upLink:["tg01"],downLink:[]},
    {id:"b_ineq_02",diff:1,content:"解：-2x<6",answer:"x>-3",sol:"除以-2变号！",error:"除以负数变号",upLink:["tg01"],downLink:[]},
    {id:"b_ineq_03",diff:2,content:"不等式组：{x>1, x≤4}，整数解",answer:"2,3,4",sol:"交集1<x≤4",error:"取交集",upLink:["tg01"],downLink:[]},
    {id:"b_ineq_04",diff:2,content:"不等式组：{2x-1>3, 3x<x+6}",answer:"2<x<3",sol:"x>2且x<3",error:"各解再取交集",upLink:["tg01"],downLink:[]},
    {id:"b_ineq_05",diff:2,content:"2x+a>0的解为x>-1，a=？",answer:"a=2",sol:"-a/2=-1，a=2",error:"由解集反推系数",upLink:["tg01"],downLink:[]},
    {id:"b_ineq_06",diff:2,content:"解：5(x-1)>3(x+2)-1",answer:"x>5",sol:"5x-5>3x+5，x>5",error:"去括号移项",upLink:["tg01"],downLink:[]},
    {id:"b_ineq_07",diff:2,content:"解：-1≤2x-3≤5",answer:"1≤x≤4",sol:"加3再除2",error:"三元不等式同步操作",upLink:["tg01"],downLink:[]},
    {id:"b_ineq_08",diff:2,content:"解：(x-2)/3≥(x+1)/4-1",answer:"x≥-1",sol:"×12：4(x-2)≥3(x+1)-12",error:"去分母×公分母",upLink:["tg01"],downLink:[]},
    {id:"b_ineq_09",diff:3,content:"不等式5x-a≥2x+1的正整数解有3个（1,2,3），a的范围",answer:"-2≤a<1",sol:"x≥(a+1)/3；1≤(a+1)/3，4>(a+1)/3",error:"整数解个数确定范围",upLink:["tg01"],downLink:[]},
    {id:"b_ineq_10",diff:3,content:"购物：满100减20或九折，x>100时哪个优惠大？",answer:"x<200时九折更优，x>200时减20更优",sol:"x-20 vs 0.9x：差=0.1x-20",error:"列不等式比较",upLink:["tg01"],downLink:[]},
    {id:"b_ineq_11",diff:2,content:"已知a<b，化简|a-b|",answer:"b-a",sol:"a<b→a-b<0，|a-b|=b-a",error:"绝对值根据正负",upLink:["tg01"],downLink:[]},
    {id:"b_ineq_12",diff:2,content:"解：(2x-1)/3>(x+1)/2",answer:"x>5",sol:"×6：2(2x-1)>3(x+1)，x>5",error:"分数不等式去分母",upLink:["tg01"],downLink:[]},
    {id:"b_ineq_13",diff:3,content:"生产x件，成本3x+100，单价8，至少产多少不亏损？",answer:"x≥20件",sol:"8x≥3x+100，x≥20",error:"利润≥0→收入≥成本",upLink:["tg01"],downLink:[]},
    {id:"b_ineq_14",diff:3,content:"不等式组{ax>3, x>b}解集为x>1，a+b=？",answer:"a=3，b=1，a+b=4",sol:"3/a=1→a=3；b=1",error:"由解集确定参数",upLink:["tg01"],downLink:[]},
    {id:"b_ineq_15",diff:2,content:"不等式组无解：{x>a, x<3}",answer:"a≥3",sol:"a≥3时两个集合无交集",error:"不等式组无解条件",upLink:["tg01"],downLink:[]},
    {id:"b_ineq_16",diff:2,content:"速度不低于60km/h，不超过2小时，距离最多？",answer:"最多120km",sol:"距离≤60×2=120",error:"不等式表示范围",upLink:["tg01"],downLink:[]},
    {id:"b_ineq_17",diff:3,content:"若a>b>0，比较a+1/b 与 b+1/a",answer:"a+1/b>b+1/a（当ab>1时）",sol:"差=(a-b)-(1/a-1/b)=(a-b)(1-1/(ab))",error:"作差法+符号分析",upLink:["tg01"],downLink:[]},
    {id:"b_ineq_18",diff:2,content:"解不等式：x²-4>0",answer:"x>2或x<-2",sol:"x²>4→|x|>2",error:"二次不等式（初步认识）",upLink:["tg01"],downLink:[]},
    {id:"b_ineq_19",diff:3,content:"关于x的不等式ax+b>0（a≠0），若解集为x<-2，则a和b的符号及关系是？",answer:"a<0，b<0，且b/a=2（即-b/a=-2）",sol:"ax>-b；a<0时x<-b/a=-2；故-b/a=-2→b=2a；a<0则b=2a<0",error:"含参不等式：a<0时除以a变号",upLink:["tg01"],downLink:[]},
    {id:"b_ineq_20",diff:2,content:"某工厂计划生产不超过500件产品，已生产了120件，还能继续生产多少件？列不等式",answer:"x≤380",sol:"120+x≤500；x≤380",error:"'不超过'用≤，'至少'用≥",upLink:["tg01"],downLink:[]},
  ],
  coords:[
    {id:"b_coo_01",diff:1,content:"A(3,-2)在第几象限？",answer:"第四象限",sol:"x>0，y<0",error:"象限判断",upLink:["tg13"],downLink:[]},
    {id:"b_coo_02",diff:1,content:"A(2,3)关于x轴对称点",answer:"B(2,-3)",sol:"y取反",error:"x轴对称纵坐标取反",upLink:["tg13"],downLink:[],
     svg:`<svg width="195" height="175" viewBox="0 0 195 175" xmlns="http://www.w3.org/2000/svg" style="background:#0d1825;border-radius:8px;display:block">
